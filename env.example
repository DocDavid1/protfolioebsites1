# ═══════════════════════════════════════════════════════════════════
# Fighters Builders — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Create a project at https://supabase.com and copy these values from
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service-role key (server only — bypasses RLS, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Drizzle / legacy — optional if using Supabase only) ─
# POSTGRES_URL=postgresql://user:password@localhost:5432/fighters_builders

# ── Authentication (BetterAuth — existing user features) ─────────
# BETTER_AUTH_SECRET=at-least-32-character-random-string

# ── AI via OpenRouter ─────────────────────────────────────────────
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── File Storage (optional — Vercel Blob for legacy uploads) ──────
BLOB_READ_WRITE_TOKEN=
