# ═══════════════════════════════════════════════════════════════════
# Fighters Builders — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Business identity (used in footer, legal pages, contact) ─────
NEXT_PUBLIC_BUSINESS_NAME=Fighters Builders
NEXT_PUBLIC_BUSINESS_NAME_HE=פייטרס בילדרס
NEXT_PUBLIC_BUSINESS_EMAIL=hello@fightersbuilders.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@fightersbuilders.com
NEXT_PUBLIC_BUSINESS_PHONE=+972-50-000-0000
NEXT_PUBLIC_WHATSAPP_NUMBER=972500000000
NEXT_PUBLIC_BUSINESS_ADDRESS=ישראל
NEXT_PUBLIC_BUSINESS_REGISTRATION=
NEXT_PUBLIC_PRIVACY_OFFICER=מנהל הפרטיות

# ── AI via OpenRouter ─────────────────────────────────────────────
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Lead Generation — Google Places API ──────────────────────────
# Enable "Places API (New)" in Google Cloud Console
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=

# ── File Storage (optional — Vercel Blob for uploads) ────────────
BLOB_READ_WRITE_TOKEN=
